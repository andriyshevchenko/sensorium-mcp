# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-forum-supergroup-chat-id

# ── Recommended ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...              # Whisper transcription, TTS voice messages, memory consolidation

# ── Optional ──────────────────────────────────────────────────────────────────
# MCP_HTTP_PORT=3847               # Enable HTTP/SSE transport (required for multi-thread agent spawning)
# MCP_HTTP_SECRET=                  # Shared secret for HTTP transport authentication
# MCP_HTTP_BIND=127.0.0.1          # Bind address for HTTP server (default: 127.0.0.1)
# WAIT_TIMEOUT_MINUTES=120         # How long wait_for_instructions blocks (default: 1440)
# VOICE_ANALYSIS_URL=              # Voice emotion analysis microservice URL
# CONSOLIDATION_ENABLED=true       # Set to false to disable LLM-based memory consolidation
# CONSOLIDATION_MODEL=gpt-4o       # OpenAI model for memory consolidation
# REFLECTION_MODEL=                # Model for reflection pipeline (falls back to CONSOLIDATION_MODEL)
# NARRATIVE_MODEL=                 # Model for narrative generation (falls back to CONSOLIDATION_MODEL)
# AUTONOMOUS_MODE=false            # Enable autonomous agent behavior
# DMN_ACTIVATION_HOURS=4           # Hours of idle before DMN reflection fires
# TELEGRAM_SUPERVISOR_TOKEN=       # Separate bot token for supervisor DM commands (avoids 409 conflict)
# DEBUG=1                          # Enable debug-level logging
